<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.text.Text?>
<VBox alignment="CENTER" spacing="10" stylesheets="@../StyleCSS/tracking.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.minotor.desktop_minotor.controller.TrackingController">

    <!--    <Label alignment="CENTER" contentDisplay="CENTER" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Historique Des Visites" textAlignment="CENTER" />-->
    <Text text="Historique Des Visites" textAlignment="CENTER" styleClass="title-text" />


    <TableView fx:id="visitTable" prefHeight="400.0" prefWidth="500.0">
        <columns>
            <TableColumn fx:id="pageColumn" prefWidth="250.0" text="Page Visité" />
            <TableColumn fx:id="dateColumn" prefWidth="250.0" text="Date De Visite" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

</VBox>
