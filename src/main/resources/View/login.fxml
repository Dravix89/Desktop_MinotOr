<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="600.0" spacing="15" stylesheets="@../StyleCSS/login.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.minotor.desktop_minotor.controller.LoginController">

    <TextField fx:id="usernameField" maxWidth="300.0" prefWidth="300.0" promptText="Nom D'Utilisateur" />
    <PasswordField fx:id="passwordField" maxWidth="300.0" prefWidth="300.0" promptText="Mot De Passe" />
    <Button fx:id="loginButton" maxWidth="150.0" prefWidth="150.0" text="Connexion" />

</VBox>
